library(caper)
MammalTree <-read.tree("species_list.nwk")
plot(MammalTree)
Mammals <- comparative.data(phy = MammalTree, data = merged_df, names.col = Species, vcv = TRUE, na.omit = FALSE, warn.dropped = TRUE)
Mammals$dropped
pgls.EI_ratio.logBrainmass <- pgls(EI_ratio ~ log(brain_mass), data = Mammals)
summary(pgls.EI_ratio.logBrainmass)
anova(pgls.EI_ratio.logBrainmass)
# Get residuals from the PGLS model pgls.EI_ratio.logBrainmass
residuals_pgls.EI_ratio.logBrainmass <- residuals(pgls.EI_ratio.logBrainmass)
# Extract species names
species_names <- rownames(residuals_pgls.EI_ratio.logBrainmass)
# Extract residuals
residuals_values <- residuals_pgls.EI_ratio.logBrainmass[, 1]
# Extract the EI_ratio column from the merged_df dataframe as a vector
residuals_vector <- setNames(residuals_values, species_names)
fit<-fastAnc(tree,residuals_vector,vars=TRUE,CI=TRUE)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,residuals_vector,plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(0.7,0.9))
# Add label to the plot
title(main = "ANCESTRAL TRAIT RECONSTRUCTION residuals pgls.EI_ratio.logBrainmass", cex.main = .5)
