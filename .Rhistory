target_columns <- which(colnames(translating_time_dataset) == "Vicugna_pacos.Value"):which(colnames(translating_time_dataset) == "Ovis_aries.Environment")
# Extract column names ending with ".Reference" within the target columns
reference_columns <- colnames(translating_time_dataset)[target_columns][grepl("\\.Reference$", colnames(translating_time_dataset)[target_columns])]
# Initialize a list to store column names, row numbers, and values in Rattus_norvegicus.Sex column
tab_containing_info <- list()
# Iterate over each column
for (col in reference_columns) {
# Exclude rows where Event is one of the 5 heading rows
temp_df <- translating_time_dataset[-c(1:5), ]
# Check for unique values containing a tab and store column name, row number, and value in Rattus_norvegicus.Sex column
for (row in seq_len(nrow(temp_df))) {
if (grepl("\t", temp_df[row, col])) {
tab_containing_info[[paste("Column", col, "Row", row)]] <- list(
Value_with_tab = temp_df[row, col],
Rattus_norvegicus_Sex = temp_df[row, "Rattus_norvegicus.Sex"]
)
}
}
}
# Print the column names, row numbers, and values in Rattus_norvegicus.Sex column associated with the unique values containing a tab
print(tab_containing_info)
# Initialize a list to store column names, row numbers, and values in Rattus_norvegicus.Sex column
tab_containing_info <- list()
for (col in reference_columns) {
for (row in seq_len(nrow(translating_time_dataset))) {
if (grepl("\t", translating_time_dataset[row, col])) {
reference_value <- translating_time_dataset[row, col]
sex_value <- translating_time_dataset[row, "Rattus_norvegicus.Sex"]
# Check if the substring after \t in Rattus_norvegicus.Reference is the same as the full string in Rattus_norvegicus.Sex
if (substring(reference_value, regexpr("\t", reference_value) + 1, nchar(reference_value)) == sex_value) {
# Remove the matched substring from Rattus_norvegicus.Reference
translating_time_dataset[row, col] <- gsub(paste0("\\t", sex_value), "", reference_value)
}
}
}
}
duplicates <- duplicated(translating_time_dataset)
if (any(duplicates)) {
print("Duplicated rows found across all columns:")
print(translating_time_dataset[duplicates, ])
} else {
print("No duplicated rows found that are identical across all columns.")
}
cleaned_dataset <- translating_time_dataset[!(is.na(translating_time_dataset$`ID-specific-archive`) & is.na(translating_time_dataset$Event)), ]
duplicates <- duplicated(cleaned_dataset[, c("ID-specific-archive", "Event")]) | duplicated(cleaned_dataset[, c("ID-specific-archive", "Event")], fromLast = TRUE)
if (any(duplicates)) {
print("Duplicated rows found based on ID-specific-archive and Event (excluding NA values):")
print(cleaned_dataset[duplicates, ])
} else {
print("No duplicated rows found based on ID-specific-archive and Event (excluding NA values).")
}
# Check for conflicts between Event_category and ID-specific-.Environment
conflict_indices <- translating_time_dataset$Event_category != translating_time_dataset$`ID-specific-.Environment`
# Filter rows where conflict_indices is TRUE and not NA
conflict_rows <- which(conflict_indices & !is.na(conflict_indices))
# Identify non-NA rows from columns 19 to 261
non_na_rows <- apply(translating_time_dataset[, 19:261], 1, function(row) any(!is.na(row)))
# Get the common rows between conflict_rows and non_na_rows
common_rows <- intersect(conflict_rows, which(non_na_rows))
# Filter dataset based on common rows
conflict_df <- translating_time_dataset[common_rows, ]
# Get column indices for those ending with .Environment
environment_cols <- grep("\\.Environment$", names(conflict_df))
# Get column indices for Event_category and ID columns
event_category_col <- grep("Event_category", names(conflict_df))
id_col <- grep("^ID$", names(conflict_df))
id_arch_col <- grep("ID-specific-archive", names(conflict_df))
event_col <- grep("^Event$", names(conflict_df))
# Combine all column indices
selected_cols <- c(id_col,id_arch_col, event_col, event_category_col, environment_cols)
# Filter dataset to include selected columns
conflict_df <- conflict_df[, selected_cols, drop = FALSE]
conflict_df
# Summary:
# 133M/FColony:
# Conflict: ID-specific-.Environment == Captive Colony ; Event_category  == Captive
## Vicugna_pacos. "Captive" Livestock
## Papio_anubis. "Captive Colony" The paper has other species of Papio spp. as well and indicates the specific species'. This seems to have been calculated.
## Mustela_putorius. "Captive" Companion animal
# Final data rows:
## 133M/FColony w/ 133 Captive Colony Males+Females: Papio_anubis <-- changed Event_category to Captive Colony, deleted Mustela_putorius, Vicugna_pacos
## 133M/FColony_Duplicate w/ 133 Captive Males+Females: Mustela_putorius, Vicugna_pacos <-- duplicated row, changed ID-specific-.Environment to Captive, deleted Papio_anubis
# View rows
translating_time_dataset[which(translating_time_dataset$ID == "133.0" & translating_time_dataset$Event == "Average age of neoplasia "), ]
## Duplicate row 133M/FColony, edit it, and append it
# Find the row index where ID-specific-archive is equal to "133M/FColony"
row_index <- which(translating_time_dataset$`ID-specific-archive` == "133M/FColony")
# Subset the row to duplicate
row_to_duplicate <- translating_time_dataset[row_index, ]
# Change the value in the ID-specific-archive column to "133M/FColony_Duplicate"
row_to_duplicate$`ID-specific-archive` <- "133M/FColony_Duplicate"
# Change the value in the ID-specific-.Environment column to "Captive"
row_to_duplicate$`ID-specific-.Environment` <- "Captive"
# Delete values for specific columns in the duplicated row
row_to_duplicate[c("Papio_anubis.Value", "Papio_anubis.Reference", "Papio_anubis.Sex")] <- NA
# Append the edited row to the dataframe right after the original row
translating_time_dataset <- rbind(translating_time_dataset[seq_len(row_index), ],
row_to_duplicate,
translating_time_dataset[-seq_len(row_index), ])
# Reset row numbers in translating_time_dataset
rownames(translating_time_dataset) <- NULL
## Edit original row 133M/FColony
# Change the value in the Event_category column to "Captive Colony"
translating_time_dataset$Event_category[row_index] <- "Captive Colony"
# Delete values for specific columns in the original row
translating_time_dataset[row_index, c("Vicugna_pacos.Value", "Vicugna_pacos.Reference", "Mustela_putorius.Value", "Mustela_putorius.Reference", "Mustela_putorius.Sex")] <- NA
# View rows
translating_time_dataset[which(translating_time_dataset$ID == "133.0" & translating_time_dataset$Event == "Average age of neoplasia "), ]
# Find the specific row where multiple conditions are met
row_specifically <- which(translating_time_dataset$`ID-specific-archive` == "179FemaleCaptive Colonies" &
translating_time_dataset$`Event-archive` == "Toal protein_ % plateaus female -Auburn clinic")
row_specifically
# Get the ID value for row_specifically
translating_time_dataset[row_specifically, "ID"]
# Check if TRUE that there is only 1 row_specifically
length(row_specifically) == 1
# Check all unique values in row_specifically
cat("Unique values:", paste0(sQuote(unique(as.vector(translating_time_dataset[row_specifically, ])))))
# Get the error in row specifically
# For context, view all rows corresponding to the same ID
translating_time_dataset[which(translating_time_dataset$ID == translating_time_dataset[row_specifically, "ID"]), ]
#In row_specifically, change "ID-specific-.Environment" to "Captive client owned" to match Event.Environment and Event_category
translating_time_dataset$`ID-specific-.Environment`[row_specifically] <- translating_time_dataset$Event.Environment[row_specifically]
# Change Event_category to "Wild" where ID = "453.0" and ID-specific-.Environment = "Wild"
translating_time_dataset$Event_category[translating_time_dataset$ID == "453.0" &
translating_time_dataset$`ID-specific-.Environment` == "Wild"] <- "Wild"
print(unique(as.vector(translating_time_dataset[row_specifically,])))
print(unique(translating_time_dataset[row_specifically,]))
