convert_terms <- function(data, search_strings, replacement_text) {
# Get all columns ending in ".Environment"
#environment_columns <- grep("\\.Environment$", names(data), value = TRUE)
# Update all columns ending in ".Environment"
for (col in environment_columns) {
data[[col]] <- ifelse(toupper(data[[col]]) %in% toupper(search_strings), replacement_text, data[[col]])
}
return(data)
}
