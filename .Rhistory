# Load data
Traits <- read_excel("~/Library/CloudStorage/OneDrive-AllenInstitute/Species/Mammalian M1 Evo - Species metadata.xlsx", sheet = "Traits")
# Replace spaces and non-standard characters in column names with periods
colnames(Traits) <- make.names(colnames(Traits), unique = TRUE)
# merge the CellVariables and Traits data frames by the "Species" and "species_sci...3" columns, respectively
merged_df <- merge(CellVariables, Traits, by.x = "Species", by.y = "species_sci...3")
merged_df
# Add underscores to species names in the merged_df dataframe
merged_df$Species <- gsub(" ", "_", merged_df$Species)
# Extract the EI_ratio column from the merged_df dataframe as a vector
trait <- setNames(merged_df$EI_ratio, merged_df$Species)
# Load phylogenetic tree
tree <- read.tree("species_phylo.nwk")
# Check the structure of your data and tree
str(merged_df)
# Plot the phylogenetic tree with branch lengths
plot(tree)
edgelabels(round(tree$edge.length, digits = 0),
adj = c(0.5, -.1),
#cex = 0.75,
frame = "none",
#bg = "transparent",
col = "blue"  # Set the color of edge labels to blue
)
vcvtree<-vcv(tree)
write.xlsx(as.data.frame(vcvtree), "vcvtree.xlsx")
# You can restore the plotted tree from the variance covariance matrix
vcv2phylotree<-vcv2phylo(vcvtree, tolerance = 1e-7)
plot(vcv2phylotree)
phylosig(tree,trait, method="K",test=TRUE)
phylosig(tree,trait, method="lambda",test=TRUE)
a = phylosig(tree,trait, method="lambda",test=TRUE)
plot(a)
# Force Ultrametric
tree_new = force.ultrametric(tree)
fitBM <- fitContinuous(phy = tree_new, dat = trait, model="BM")
fitOU <- fitContinuous(phy = tree_new, dat = trait, model="OU")
fitEB <- fitContinuous(phy = tree_new, dat = trait, model="EB")
aic.vals<-setNames(c(fitBM$opt$aicc,fitOU$opt$aicc,fitEB$opt$aicc),
c("BM","OU","EB"))
aic.vals
aic.w(aic.vals)
fit<-fastAnc(tree,trait,vars=TRUE,CI=TRUE)
fit
## as we discussed in class, 95% CIs can be broad
fit$CI[1,]
range(trait)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,trait,plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(1,0.9))
# Add label to the plot
title(main = "ANCESTRAL TRAIT RECONSTRUCTION E:I ratio", cex.main = .5)
brain_mass <- setNames(merged_df$brain_mass, merged_df$Species)
phylosig(tree,log(brain_mass), method="K",test=TRUE)
phylosig(tree,log(brain_mass), method="lambda",test=TRUE)
fitBM_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="BM")
fitOU_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="OU")
fitEB_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="EB")
## AIC values
aic.vals_logbrain<-setNames(c(fitBM_logbrain$opt$aicc,fitOU_logbrain$opt$aicc,fitEB_logbrain$opt$aicc),
c("BM_logbrain","OU_logbrain","EB_logbrain"))
aic.vals_logbrain
## AIC weights
aic.w(aic.vals_logbrain)
fit<-fastAnc(tree,log(brain_mass),vars=TRUE,CI=TRUE)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,log(brain_mass),plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(1,0.9))
# Add label to the plot
title(main = "ANCESTRAL TRAIT RECONSTRUCTION log(brain_mass)", cex.main = .5)
fitBM$opt$sigsq
fitOU$opt$sigsq
fitEB$opt$sigsq
fitBM_logbrain$opt$sigsq
fitOU_logbrain$opt$sigsq
fitEB_logbrain$opt$sigsq
# Define colors based on phylogenetic clade information
phylo_levels <- unique(merged_df$phylo2_sci)
phylo_colors <- brewer.pal(length(phylo_levels), "Set3")
# Plot EI_ratio ~ log brain_mass with separate regression lines for each clade
plot(EI_ratio ~ log(brain_mass), data = merged_df,
col = phylo_colors[as.numeric(factor(merged_df$phylo2_sci))],
pch = 19,
cex = 1.5,  # Increase point size
xlab = "Log(Brain Mass)",
ylab = "E:I Ratio",
main = "Mean E:I Ratio vs. Log(Brain Mass)")
clades <- unique(merged_df$phylo2_sci)
# Reorder the levels of phylo2_sci according to the order of colors
merged_df$phylo2_sci <- factor(merged_df$phylo2_sci, levels = clades)
# Add legend
legend("topright", legend = levels(merged_df$phylo2_sci), col = phylo_colors, pch = 19,
title = "Clade", cex = 0.8)
# Get residuals from the model EI_ratio.logBrainmass
residual_values <- residuals(lm(EI_ratio ~ log(brain_mass), data = merged_df))
# Extract species names
species_names <- merged_df$Species
# Extract the EI_ratio column from the merged_df dataframe as a vector
residuals_EI_ratio.logBrainmass <- setNames(residual_values, species_names)
phylosig(tree,residuals_EI_ratio.logBrainmass, method="K",test=TRUE)
phylosig(tree,residuals_EI_ratio.logBrainmass, method="lambda",test=TRUE)
fitBM_EI.logbrain <- fitContinuous(phy = tree_new, dat = residuals_EI_ratio.logBrainmass, model="BM")
fitOU_EI.logbrain <- fitContinuous(phy = tree_new, dat = residuals_EI_ratio.logBrainmass, model="OU")
fitEB_EI.logbrain <- fitContinuous(phy = tree_new, dat = residuals_EI_ratio.logBrainmass, model="EB")
## AIC values
aic.vals_EI.logbrain<-setNames(c(fitBM_EI.logbrain$opt$aicc,fitOU_EI.logbrain$opt$aicc,fitEB_EI.logbrain$opt$aicc),
c("BM_EI.logbrain","OU_EI.logbrain","EB_EI.logbrain"))
aic.vals_EI.logbrain
## AIC weights
aic.w(aic.vals_EI.logbrain)
fit<-fastAnc(tree,residuals_EI_ratio.logBrainmass,vars=TRUE,CI=TRUE)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,residuals_EI_ratio.logBrainmass,plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(1,0.9))
