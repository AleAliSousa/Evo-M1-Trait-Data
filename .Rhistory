merged_df<- read_csv("merged_df.csv")
# Load phylogenetic tree
tree <- read.tree("tree.nwk")
# Create a new dataframe with merged_df and residuals directly
new_df <- data.frame(merged_df, "res.Ei.lnBr" = residuals(lm(EI_ratio ~ log(brain_mass), data = merged_df)))
# Add log(brain_mass)
new_df$lnBr <- log(new_df$brain_mass)
# Create a vector for EI_ratio ~ log(brain_mass)
res.Ei.lnBr<- setNames(new_df$res.Ei.lnBr, new_df$Species)
# RRphylo says best if data vectors are sorted in the same order of the species on the phylogeny, so reorder the vector res.Ei.lnBr
res.Ei.lnBr <- res.Ei.lnBr[match(tree$tip.label,names(res.Ei.lnBr))]
# Calculate evolutionary rates and trends on a phylogenetic tree (tree) using trait data (res.Ei.lnBr).
RR <- RRphylo(tree=tree,y=res.Ei.lnBr)
summary(RR)
# Visualize the results of RRphylo analysis.
pRR = plotRR(RR, y = res.Ei.lnBr, multivariate = "rates")
# Plot illustrating the phenotypic trend through time for the specified variable.
pRR$plotRRphen(variable = 1,
tree.args = list(edge.width = 2, cex = 0.7),
#color.pal = topo.colors,
colorbar.args = list(x = "topleft", y = "top", width = 0.6, direction = "h", labs.adj = 0.05, xpd = TRUE))
# The RRphylo function calculates rates of evolution on branches of the phylogenetic tree using residual trait data
pRR$plotRRrates(variable = 1,
tree.args = list(edge.width = 2, direction = "leftwards", cex = 0.7),
#color.pal = topo.colors,
#colorbar.args = list(x = 0.8, y = 0.95, width = 0.05, labs.adj = 0.7, xpd = TRUE))
colorbar.args = list(x = "topright", y = "top", width = 0.6, direction = "h", labs.adj = 0.05, xpd = TRUE))
# SSauto stores the results of searching for rate shifts within a clade using search.shift
SSauto  = search.shift(RR = RR, status.type = "clade")
#Plot significant shifts in evolutionary rates and trends based on the summary statistics provided
plotSS = plotShift(RR = RR, SS = SSauto)
#Plot showing the identified clades with significant shifts in evolutionary rates and trends
plotSS$plotClades()
plotSS$plotClades(tree.args=list(no.margin=TRUE,type="fan"),
symbols.args=list(lwd=2,fg=c(pos="blue",neg="red"),
bg=scales::alpha("grey70",0.3)))
# Create a vector for EI_ratio
EI<- setNames(new_df$EI_ratio, new_df$Species)
# RRphylo says best if data vectors are sorted in the same order of the species on the phylogeny, so reorder the vector EI
EI <- EI[match(tree$tip.label,names(EI))]
# Calculate evolutionary rates and trends on a phylogenetic tree (tree) using trait data (res.Ei.lnBr).
RR <- RRphylo(tree=tree,y=EI)
summary(RR)
# Visualize the results of RRphylo analysis.
pRR = plotRR(RR, y = EI, multivariate = "rates")
# Plot illustrating the phenotypic trend through time for the specified variable.
pRR$plotRRphen(variable = 1,
tree.args = list(edge.width = 2, cex = 0.7),
#color.pal = topo.colors,
colorbar.args = list(x = "topleft", y = "top", width = 0.6, direction = "h", labs.adj = 0.05, xpd = TRUE))
# The RRphylo function calculates rates of evolution on branches of the phylogenetic tree using residual trait data
pRR$plotRRrates(variable = 1,
tree.args = list(edge.width = 2, direction = "leftwards", cex = 0.7),
#color.pal = topo.colors,
#colorbar.args = list(x = 0.8, y = 0.95, width = 0.05, labs.adj = 0.7, xpd = TRUE))
colorbar.args = list(x = "topright", y = "top", width = 0.6, direction = "h", labs.adj = 0.05, xpd = TRUE))
# SSauto stores the results of searching for rate shifts within a clade using search.shift
SSauto  = search.shift(RR = RR, status.type = "clade")
#Plot significant shifts in evolutionary rates and trends based on the summary statistics provided
plotSS = plotShift(RR = RR, SS = SSauto)
