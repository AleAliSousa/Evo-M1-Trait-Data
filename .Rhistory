#Create a new data frame with counts by subclass
count_meta_m1_subclass <-
meta_m1 %>%
group_by(Species, predicted.id) %>%
count()
#Gather data frame
count_meta_m1_subclass_gathered <-
count_meta_m1_subclass %>%
tidyr::spread(predicted.id, n)
count_meta_m1_subclass_gathered
CellVariables <- merge(EI_ratios, count_meta_m1_subclass_gathered)
library(readxl)
# Load data
Traits <- read_excel("~/Library/CloudStorage/OneDrive-AllenInstitute/Species/Mammalian M1 Evo - Species metadata.xlsx", sheet = "Traits")
# Replace spaces and non-standard characters in column names with periods
colnames(Traits) <- make.names(colnames(Traits), unique = TRUE)
# # Add underscores to species_sci...3 names in the Traits dataframe
# Traits$species_sci...3 <- gsub(" ", "_", Traits$species_sci...3)
# assume that CellVariables and Traits are already loaded in your environment
# merge the CellVariables and Traits data frames by the "Species" and "species_sci...3" columns, respectively
merged_df <- merge(CellVariables, Traits, by.x = "Species", by.y = "species_sci...3")
# print the merged data frame
merged_df
library(ape)  # For phylogenetic tree manipulation
library(phytools)  # For phylogenetic analysis
# Problem with Saimiri - create a temp renamed version
# Duplicate the dataframe EI_ratios and assign it to EI_ratios_temp
merged_df_temp <- data.frame(merged_df)
# Rename Species Saimiri boliviensis boliviensis to Saimiri boliviensis in EI_ratios_temp
merged_df_temp <- merged_df_temp %>%
mutate(Species = ifelse(Species == "Saimiri boliviensis boliviensis", "Saimiri boliviensis", Species))
# Export Species list to get a tree from https://timetree.org/
write.table(merged_df_temp$Species, file = "species_list.txt", row.names = FALSE, col.names = FALSE, quote = FALSE)
# The tree needs an updated name
tree <- read.tree("species_list.nwk")
tree$tip.label[tree$tip.label=="Saimiri_boliviensis"] <- "Saimiri_boliviensis_boliviensis"
write.tree(tree, "species_list.nwk")
# Add underscores to species names in the merged_df dataframe
merged_df$Species <- gsub(" ", "_", merged_df$Species)
# Extract the EI_ratio column from the merged_df dataframe as a vector
trait <- setNames(merged_df$EI_ratio, merged_df$Species)
# Load your phylogenetic tree
tree <- read.tree("species_list.nwk")
# Check the structure of your data and tree
str(merged_df)
plot(tree)
phylosig(tree,trait, method="K",test=TRUE)
phylosig(tree,trait, method="lambda",test=TRUE)
a = phylosig(tree,trait, method="lambda",test=TRUE)
plot(a)
library(geiger)
# Force Ultrametric
tree_new = force.ultrametric(tree)
fitBM <- fitContinuous(phy = tree_new, dat = trait, model="BM")
fitOU <- fitContinuous(phy = tree_new, dat = trait, model="OU")
fitEB <- fitContinuous(phy = tree_new, dat = trait, model="EB")
aic.vals<-setNames(c(fitBM$opt$aicc,fitOU$opt$aicc,fitEB$opt$aicc),
c("BM","OU","EB"))
aic.vals
aic.w(aic.vals)
library(phytools)
fit<-fastAnc(tree,trait,vars=TRUE,CI=TRUE)
fit
## as we discussed in class, 95% CIs can be broad
fit$CI[1,]
range(trait)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,trait,plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(0.7,0.9))
phenogram(tree,trait,fsize=0.6,spread.costs=c(1,0))
brain_mass <- setNames(merged_df$brain_mass, merged_df$Species)
phylosig(tree,log(brain_mass), method="K",test=TRUE)
phylosig(tree,log(brain_mass), method="lambda",test=TRUE)
fitBM_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="BM")
fitOU_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="OU")
fitEB_logbrain <- fitContinuous(phy = tree_new, dat = log(brain_mass), model="EB")
## AIC values
aic.vals_logbrain<-setNames(c(fitBM_logbrain$opt$aicc,fitOU_logbrain$opt$aicc,fitEB_logbrain$opt$aicc),
c("BM_logbrain","OU_logbrain","EB_logbrain"))
aic.vals_logbrain
## AIC weights
aic.w(aic.vals_logbrain)
fit<-fastAnc(tree,log(brain_mass),vars=TRUE,CI=TRUE)
## projection of the reconstruction onto the edges of the tree
obj<-contMap(tree,log(brain_mass),plot=FALSE)
plot(obj,type="fan",legend=0.7*max(nodeHeights(tree)),
fsize=c(0.7,0.9))
fitBM$opt$sigsq
fitOU$opt$sigsq
fitEB$opt$sigsq
fitBM_logbrain$opt$sigsq
fitOU_logbrain$opt$sigsq
fitEB_logbrain$opt$sigsq
