# Initialize an empty dataframe to store the matching entries
matching_entries <- data.frame(Row_Number = integer(), Column_Number = integer(), Column_Header = character(), Value = character(), stringsAsFactors = FALSE)
# Define the range of columns
#target_columns <- 20:259
target_columns <- which(colnames(translating_time_dataset) == "Vicugna_pacos.Value"):which(colnames(translating_time_dataset) == "Ovis_aries.Environment")
# Iterate over the columns
for (col_index in target_columns) {
# Check if the second row value is not ".Reference" (since these have a lot of terms)
if (translating_time_dataset[1, col_index] != ".Reference") {
# Check if any value in the column contains both a sex term and an environment term
matching_rows <- which(grepl("sex|M/F|MF|Female|Male", translating_time_dataset[, col_index], ignore.case = TRUE) &
grepl("environment|Wild/Captive|Wild|Captive", translating_time_dataset[, col_index], ignore.case = TRUE))
# If any matching rows are found, store the row and column indices
if (length(matching_rows) > 0) {
# Extract column header
column_header <- colnames(translating_time_dataset)[col_index]
# Extract column value
column_value <- translating_time_dataset[matching_rows, col_index]
# Create a dataframe with the matching entries
matching_subset <- data.frame(Row_Number = matching_rows, Column_Number = col_index, Column_Header = column_header, Value = column_value, stringsAsFactors = FALSE)
# Combine with the existing matching_entries dataframe
matching_entries <- rbind(matching_entries, matching_subset)
}
}
}
# Inspect the matching entries
matching_entries
# Initialize a vector to store the prefixes
prefixes <- character()
# Iterate over the matching entries from the previous loop
for (i in 1:nrow(matching_entries)) {
# Extract the column header
col_header <- matching_entries[i, "Column_Header"]
# Extract the prefix
prefix <- sub("\\.Sex.*", "", col_header)  # Extract the prefix before ".Sex"
# Check if the prefix has not been encountered before and also has ".Environment" column
if (!(prefix %in% prefixes) && any(grepl(paste0("^", prefix, "\\.Environment"), colnames(translating_time_dataset)))) {
# Store the prefix
prefixes <- c(prefixes, prefix)
}
}
# Initialize an empty dataframe to store the .Sex and .Environment columns
sex_environment_df <- data.frame(Row_Number = integer(), Species = character(), Sex = character(), Environment = character(), stringsAsFactors = FALSE)
# Iterate over the prefixes
for (prefix in prefixes) {
# Extract the .Sex column
sex_col <- paste0(prefix, ".Sex")
# Extract the .Environment column
env_col <- paste0(prefix, ".Environment")
# Extract the values from the dataset for the current prefix
sex_values <- translating_time_dataset[, sex_col]
env_values <- translating_time_dataset[, env_col]
# Extract row numbers
row_numbers <- which(!is.na(sex_values) | sex_values != "" | !is.na(env_values) | env_values != "")
# Combine the values into a dataframe
prefix_df <- data.frame(Row_Number = row_numbers, Species = rep(prefix, length(row_numbers)), Sex = sex_values[row_numbers], Environment = env_values[row_numbers], stringsAsFactors = FALSE)
# Combine with the existing dataframe
sex_environment_df <- rbind(sex_environment_df, prefix_df)
}
sex_environment_df
## Add new .Environment columns for the matching_entries species for which there is no column for .Environment yet
# Function to add .Environment column if it doesn't exist for a given prefix
add_environment_column <- function(data, prefix) {
new_column <- paste0(prefix, ".Environment")
# Check if .Environment column already exists
if (!(new_column %in% colnames(data))) {
# Find the index of .Sex column
sex_index <- which(colnames(data) == paste0(prefix, ".Sex"))
# Insert .Environment column right after .Sex column
data <- data %>%
mutate(!!new_column := NA_character_) %>%
relocate(!!new_column, .after = paste0(prefix, ".Sex"))
}
return(data)
}
# Iterate over unique Column_Header values in matching_entries
unique_columns <- unique(matching_entries$Column_Header)
# Apply the function to add .Environment column for each prefix
translating_time_dataset <- reduce(str_remove(unique_columns, "\\.Sex.*"), add_environment_column, .init = translating_time_dataset)
## For each column in the character "unique_columns", iterate over each unique column header. For every row in the column containing "Captive", "Wild", or "Colony", copy the text to the corresponding .Environment column and remove it from the ID-specific column.
# Define the terms with descriptive names
terms <- c("Captive client owned", "Captive colonies", "Captive", "Wild", "Colony")
# Iterate over each unique column
for (column in unique_columns) {
# Extract the prefix
prefix <- sub("\\.Sex.*", "", column)  # Extract the prefix before ".Sex"
# Extract the .Sex and .Environment columns
sex_column <- paste0(prefix, ".Sex")
env_column <- paste0(prefix, ".Environment")
# Iterate over each term in terms
for (term in terms) {
# Find rows containing the current term in the current column
matching_rows <- grepl(term, translating_time_dataset[[column]], ignore.case = TRUE)
# If any rows contain the term
if (any(matching_rows)) {
# Copy the term to the corresponding .Environment column
translating_time_dataset[matching_rows, env_column] <- term
# Remove the term from the corresponding .Sex column
translating_time_dataset[matching_rows, sex_column] <- gsub(term, "", translating_time_dataset[matching_rows, sex_column], ignore.case = TRUE)
}
}
# Filter matching entries for the current prefix
matching_filtered <- matching_entries$Row_Number[matching_entries$Column_Header == paste0(prefix, ".Sex")]
# Print sex_column and env_column for the current prefix and matching rows
print(translating_time_dataset[matching_filtered, c(sex_column, env_column)])
}
