file_path <- "~/Library/CloudStorage/OneDrive-AllenInstitute/Species/Evo M1 Trait Data/__merging/DosSantos_etal_2017_TableS1_terms.csv"
write.csv(new_dataframe, file_path, row.names = FALSE)
