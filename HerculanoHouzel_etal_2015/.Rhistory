library(xfun)
# Set your working directory
main_directory <- "~/Library/CloudStorage/OneDrive-AllenInstitute/Species/Evo-M1-Trait-Data/HerculanoHouzel_etal_2015"
setwd(main_directory)
# List all files in the directory and its subdirectories
all_files <- list.files(recursive = TRUE)
list.files(recursive = TRUE)
# Filter for R script files
r_script_files <- all_files[endsWith(all_files, ".R")]
r_script_files
# Apply gsub to R script files
for (file in r_script_files) {
full_path <- file.path(main_directory, file)
new_file <- gsub("Evo M1 Trait Data", "Evo-M1-Trait-Data", file)
# Check if the file is not in the correct format after replacement
if (file != new_file) {
new_full_path <- file.path(main_directory, new_file)
xfun::file_rename(full_path, new_full_path)
cat("File renamed:", full_path, "->", new_full_path, "\n")
}
}
