# Repeat the process for other data frames...
# HerculanoHouzel_etal_2015_Table2
# HerculanoHouzel_etal_2015_Table3
# HerculanoHouzel_etal_2015_Table4
# HerculanoHouzel_etal_2015_Table5
# HerculanoHouzel_etal_2020_Table1
# HerculanoHouzel_etal_2020_Table2
# JardimMesseder_etal_2017_Table1
# Kverkova_etal_2018_TableS1
# Kverkova_etal_2018_TableS5
#
# assign(sub(".csv$", "", basename("path/to/your/file.csv")), read.csv("path/to/your/file.csv"))
update_colnames <- function(dataframe) {
reference_name <- deparse(substitute(dataframe))
indices <- match(
colnames(dataframe),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == reference_name]
)
colnames(dataframe) <- standardized_term_cellcounts$Standardized_Term[indices]
}
# Example usage:
update_colnames(DosSantos_etal_2017_TableS1)
update_colnames(DosSantos_etal_2020_Table1)
update_colnames(HerculanoHouzel_etal_2015_Table1)
# 2. Compile total of all datasets on cellular composition
# 2Qa. What data should be included/excluded when doing an imputation?
# 2Qb. Should data be converted if there is an equation for exact conversion? e.g. WholeBrain ; BodyMasskg
colnames(HerculanoHouzel_etal_2015_Table2)
update_colnames <- function(dataframe) {
reference_name <- deparse(substitute(dataframe))
indices <- match(
colnames(dataframe),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == reference_name]
)
colnames(dataframe) <- standardized_term_cellcounts$Standardized_Term[indices]
}
# Example usage:
update_colnames(DosSantos_etal_2017_TableS1)
update_colnames(DosSantos_etal_2020_Table1)
update_colnames(HerculanoHouzel_etal_2015_Table1)
colnames(HerculanoHouzel_etal_2015_Table2)
update_colnames <- function(df_name) {
indices <- match(
colnames(get(df_name)),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == df_name]
)
colnames(get(df_name)) <- standardized_term_cellcounts$Standardized_Term[indices]
}
# Example usage:
update_colnames("HerculanoHouzel_etal_2015_Table1")
update_colnames <- function(df_name) {
df <- get(df_name)
indices <- match(
colnames(df),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == df_name]
)
colnames(df) <- standardized_term_cellcounts$Standardized_Term[indices]
# Assign the updated dataframe back to the global environment
assign(df_name, df, envir = .GlobalEnv)
}
