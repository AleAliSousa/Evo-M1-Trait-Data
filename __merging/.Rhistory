update_colnames <- function(dataframe) {
reference_name <- deparse(substitute(dataframe))
cat("Updating column names for:", reference_name, "\n")
indices <- match(
colnames(dataframe),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == reference_name]
)
colnames(dataframe) <- standardized_term_cellcounts$Standardized_Term[indices]
}
# Apply the function to each dataframe
update_colnames(DosSantos_etal_2017_TableS1)
update_colnames(DosSantos_etal_2020_Table1)
# Repeat for other dataframes...
update_colnames(HerculanoHouzel_etal_2015_Table1)
update_colnames(HerculanoHouzel_etal_2015_Table2)
update_colnames(HerculanoHouzel_etal_2015_Table3)
update_colnames(HerculanoHouzel_etal_2015_Table4)
update_colnames(HerculanoHouzel_etal_2015_Table5)
update_colnames(HerculanoHouzel_etal_2020_Table1)
update_colnames(HerculanoHouzel_etal_2020_Table2)
update_colnames(JardimMesseder_etal_2017_Table1)
update_colnames(Kverkova_etal_2018_TableS1)
update_colnames(Kverkova_etal_2018_TableS5)
View(update_colnames)
