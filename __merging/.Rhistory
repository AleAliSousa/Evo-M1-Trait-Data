# colnames(DosSantos_etal_2020_Table1) <- standardized_term_cellcounts$Standardized_Term[DosSantos_etal_2020_Table1_indices]
update_colnames <- function(dataframe) {
indices <- match(
colnames(dataframe),
standardized_term_cellcounts$Original_Term[standardized_term_cellcounts$Reference == colnames(dataframe)]
)
colnames(dataframe) <- standardized_term_cellcounts$Standardized_Term[indices]
}
update_colnames(DosSantos_etal_2017_TableS1)
